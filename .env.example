# ── Required ────────────────────────────────────────────────────────────────
# OpenAI API key for the AI invoice agent
OPENAI_API_KEY=sk-...


# ── Optional: Auth + Rate Limiting (for hosted/production deployments) ──────
# Leave these unset for local development or self-hosted instances.
# When NEXT_PUBLIC_ENABLE_AUTH=true, users must sign in via Clerk before using AI.
# Rate limiting auto-activates when UPSTASH_REDIS_REST_URL is set.

# Feature flag — set to "true" to enable auth
NEXT_PUBLIC_ENABLE_AUTH=false

# Clerk (https://clerk.com) — get these from your Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Upstash Redis (https://upstash.com) — for per-user rate limiting (20 req/hour)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...